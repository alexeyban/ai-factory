{
  "dataset_version": "1.0",
  "difficulty": "medium",
  "tasks": [
    {
      "task_id": "bench_medium_001",
      "title": "Binary search",
      "description": "Write a Python function `binary_search(arr: list[int], target: int) -> int` that returns the index of target in a sorted list, or -1 if not found.",
      "difficulty": "medium",
      "type": "dev",
      "tests": [
        "assert binary_search([1, 3, 5, 7, 9], 5) == 2",
        "assert binary_search([1, 3, 5, 7, 9], 6) == -1",
        "assert binary_search([], 1) == -1",
        "assert binary_search([1], 1) == 0"
      ],
      "hidden_tests": [
        "assert binary_search([1, 2, 3, 4, 5], 1) == 0",
        "assert binary_search([1, 2, 3, 4, 5], 5) == 4"
      ],
      "expected_output": {
        "function_name": "binary_search",
        "signature": "def binary_search(arr: list[int], target: int) -> int"
      },
      "time_limit_ms": 200,
      "memory_limit_mb": 50
    },
    {
      "task_id": "bench_medium_002",
      "title": "Merge sort",
      "description": "Write a Python function `merge_sort(arr: list[int]) -> list[int]` that sorts a list of integers using the merge sort algorithm and returns a new sorted list.",
      "difficulty": "medium",
      "type": "dev",
      "tests": [
        "assert merge_sort([3, 1, 4, 1, 5]) == [1, 1, 3, 4, 5]",
        "assert merge_sort([]) == []",
        "assert merge_sort([1]) == [1]",
        "assert merge_sort([5, 4, 3, 2, 1]) == [1, 2, 3, 4, 5]"
      ],
      "hidden_tests": [
        "assert merge_sort([2, 2, 2]) == [2, 2, 2]",
        "assert merge_sort(list(range(10, 0, -1))) == list(range(1, 11))"
      ],
      "expected_output": {
        "function_name": "merge_sort",
        "signature": "def merge_sort(arr: list[int]) -> list[int]"
      },
      "time_limit_ms": 500,
      "memory_limit_mb": 100
    },
    {
      "task_id": "bench_medium_003",
      "title": "Valid parentheses",
      "description": "Write a Python function `is_valid_parens(s: str) -> bool` that returns True if the string containing only '(', ')', '{', '}', '[', ']' is valid (every opening bracket has a matching closing bracket in the correct order).",
      "difficulty": "medium",
      "type": "dev",
      "tests": [
        "assert is_valid_parens('()') == True",
        "assert is_valid_parens('()[]{}') == True",
        "assert is_valid_parens('(]') == False",
        "assert is_valid_parens('([)]') == False",
        "assert is_valid_parens('{[]}') == True"
      ],
      "hidden_tests": [
        "assert is_valid_parens('') == True",
        "assert is_valid_parens('(((') == False"
      ],
      "expected_output": {
        "function_name": "is_valid_parens",
        "signature": "def is_valid_parens(s: str) -> bool"
      },
      "time_limit_ms": 200,
      "memory_limit_mb": 50
    },
    {
      "task_id": "bench_medium_004",
      "title": "Longest common subsequence",
      "description": "Write a Python function `lcs_length(s1: str, s2: str) -> int` that returns the length of the longest common subsequence of two strings.",
      "difficulty": "medium",
      "type": "dev",
      "tests": [
        "assert lcs_length('abcde', 'ace') == 3",
        "assert lcs_length('abc', 'abc') == 3",
        "assert lcs_length('abc', 'def') == 0",
        "assert lcs_length('', 'abc') == 0"
      ],
      "hidden_tests": [
        "assert lcs_length('AGGTAB', 'GXTXAYB') == 4",
        "assert lcs_length('a', 'a') == 1"
      ],
      "expected_output": {
        "function_name": "lcs_length",
        "signature": "def lcs_length(s1: str, s2: str) -> int"
      },
      "time_limit_ms": 500,
      "memory_limit_mb": 100
    },
    {
      "task_id": "bench_medium_005",
      "title": "Number of islands",
      "description": "Write a Python function `num_islands(grid: list[list[str]]) -> int` that counts the number of islands in a 2D grid of '1' (land) and '0' (water).",
      "difficulty": "medium",
      "type": "dev",
      "tests": [
        "assert num_islands([['1','1','0'],['0','1','0'],['0','0','1']]) == 2",
        "assert num_islands([['0','0'],['0','0']]) == 0",
        "assert num_islands([['1']]) == 1"
      ],
      "hidden_tests": [
        "assert num_islands([['1','1','1'],['0','1','0'],['1','1','1']]) == 1",
        "assert num_islands([['1','0','1'],['0','0','0'],['1','0','1']]) == 4"
      ],
      "expected_output": {
        "function_name": "num_islands",
        "signature": "def num_islands(grid: list[list[str]]) -> int"
      },
      "time_limit_ms": 500,
      "memory_limit_mb": 100
    },
    {
      "task_id": "bench_medium_006",
      "title": "Two sum",
      "description": "Write a Python function `two_sum(nums: list[int], target: int) -> tuple[int, int]` that returns the indices of the two numbers that add up to target. Assume exactly one solution exists.",
      "difficulty": "medium",
      "type": "dev",
      "tests": [
        "assert two_sum([2, 7, 11, 15], 9) == (0, 1)",
        "assert two_sum([3, 2, 4], 6) == (1, 2)",
        "assert two_sum([3, 3], 6) == (0, 1)"
      ],
      "hidden_tests": [
        "r = two_sum([1, 5, 3, 8], 9); assert set(r) == {1, 3}",
        "r = two_sum([0, 4, 3, 0], 0); assert set(r) == {0, 3}"
      ],
      "expected_output": {
        "function_name": "two_sum",
        "signature": "def two_sum(nums: list[int], target: int) -> tuple[int, int]"
      },
      "time_limit_ms": 200,
      "memory_limit_mb": 50
    },
    {
      "task_id": "bench_medium_007",
      "title": "Group anagrams",
      "description": "Write a Python function `group_anagrams(strs: list[str]) -> list[list[str]]` that groups anagrams together. The order of groups and items within groups does not matter.",
      "difficulty": "medium",
      "type": "dev",
      "tests": [
        "result = group_anagrams(['eat','tea','tan','ate','nat','bat']); assert len(result) == 3",
        "assert group_anagrams([]) == []",
        "result = group_anagrams(['a']); assert result == [['a']]"
      ],
      "hidden_tests": [
        "result = group_anagrams(['abc','bca','cab','xyz']); assert len(result) == 2",
        "result = group_anagrams(['']); assert result == [['']]"
      ],
      "expected_output": {
        "function_name": "group_anagrams",
        "signature": "def group_anagrams(strs: list[str]) -> list[list[str]]"
      },
      "time_limit_ms": 500,
      "memory_limit_mb": 100
    },
    {
      "task_id": "bench_medium_008",
      "title": "Coin change",
      "description": "Write a Python function `coin_change(coins: list[int], amount: int) -> int` that returns the fewest number of coins needed to make up the amount, or -1 if it's not possible.",
      "difficulty": "medium",
      "type": "dev",
      "tests": [
        "assert coin_change([1, 5, 10], 11) == 2",
        "assert coin_change([2], 3) == -1",
