    {
      "task_id": "bench_medium_010",
      "title": "Flatten nested list",
      "description": "Write a Python function `flatten(nested: list) -> list` that flattens an arbitrarily nested list into a single flat list.",
      "difficulty": "medium",
      "type": "dev",
      "tests": [
        "assert flatten([1, [2, 3], [4, [5, 6]]]) == [1, 2, 3, 4, 5, 6]",
