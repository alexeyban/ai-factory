      ],
      "hidden_tests": [
        "assert coin_change([1, 2, 5], 11) == 3",
        "assert coin_change([186, 419, 83, 408], 6249) == 20"
      ],
      "expected_output": {
        "function_name": "coin_change",
        "signature": "def coin_change(coins: list[int], amount: int) -> int"
      },
      "time_limit_ms": 1000,
      "memory_limit_mb": 100
